POSTGRES_PASSWORD=replace-with-a-random-database-password
DATABASE_POOL_SIZE=8
GAME_PLATFORM_IMAGE=yuo-game-platform:local
PUBLIC_BASE_URL=https://game.dstopology.com
COOKIE_SECURE=true
SESSION_COOKIE_NAME=yuo_platform_session

# 身份认证默认保持独立部署；启用外部平台时再替换以下配置。
AUTH_LOCAL_ENABLED=true
AUTH_EXTERNAL_IMPLEMENTATION=disabled
AUTH_EXTERNAL_PROVIDER_ID=external-platform
AUTH_EXTERNAL_PROVIDER_NAME=外部账号平台
AUTH_EXTERNAL_ENTRY_URL=https://identity.example.com/api/game-platform/handoff
AUTH_EXTERNAL_ISSUER_URL=https://identity.example.com
AUTH_EXTERNAL_HANDOFF_SECRET=replace-with-at-least-32-random-bytes
AUTH_EXTERNAL_HANDOFF_MAX_TTL_SECONDS=300
AUTH_EXTERNAL_VALIDATION_TIMEOUT_MS=5000

LIFE_LAUNCH_URL=https://game.dstopology.com/life/
BILLIARDS_LAUNCH_URL=https://game.dstopology.com/billiards/
SNAKE_LAUNCH_URL=https://game.dstopology.com/snake/
FOUNDRY_LAUNCH_URL=https://game.dstopology.com/foundry/
LIFE_SERVICE_TOKEN=replace-with-a-random-service-token
BILLIARDS_SERVICE_TOKEN=replace-with-a-random-service-token
SNAKE_SERVICE_TOKEN=replace-with-a-random-service-token
FOUNDRY_SERVICE_TOKEN=replace-with-a-random-service-token
LIFE_GAME_SESSION_SECRET=replace-with-at-least-32-random-bytes
BILLIARDS_GAME_SESSION_SECRET=replace-with-at-least-32-random-bytes
SNAKE_GAME_SESSION_SECRET=replace-with-at-least-32-random-bytes
FOUNDRY_GAME_SESSION_SECRET=replace-with-at-least-32-random-bytes
